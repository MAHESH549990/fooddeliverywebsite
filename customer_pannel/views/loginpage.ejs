<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login Customer</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <form class="login-user" method="post" action="/home">
    <div class="login-info">
      <h1>Login</h1>
      <br/><br/><br/>
      <label id="label-name" for="email">Email</label>
       <br/><br/>
      <input placeholder="enter your email" name="email" type="email" id="email">
       <br/><br/><br/>
      <label id="label-name" id="password">Password</label>
       <br/><br/>
      <input placeholder="enter password" name="password" type="password" id="password">
       <br/><br/>
      <a href="#" id="a_tag">forgot password</a>
       <br/><br/> <br/><br/><br/>
      <div class="btn-div">
      <a href="/login" class="btn">Login</a> 
      <a href="/signup" class="btn" id="right-btn">Sign Up</button></a>
      </div>
      </div>
      <div class="login-image">
         <img src="/images/login-page.png">
      </div>
  </form>
</body>
</html>